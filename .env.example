# Copy this file to .env and fill in your keys.
# The program works best with all three, but each one is optional.
# With no keys you get zero results (all APIs require authentication).

# ── Apollo.io (RECOMMENDED — best results) ───────────────────────────────────
# Sign up free: https://app.apollo.io/#/sign-up
# Free plan: ~50 people exports/month.
# Gives: name, title, email, LinkedIn URL, education history.
# Your key: Settings → Integrations → API → API Key
APOLLO_API_KEY=

# ── SerpAPI (fallback if no Apollo) ──────────────────────────────────────────
# Searches Google for site:linkedin.com/in Columbia alumni at each company.
# Free: 100 searches/month. Sign up at https://serpapi.com
# Your key is on the dashboard immediately after signup.
SERPAPI_KEY=

# ── Hunter.io (email enrichment for Google hits) ─────────────────────────────
# Sign up free: https://hunter.io/users/sign_up
# Free plan: 25 domain searches/month.
# Used to attach email addresses to people found via Google Search.
# Your key: https://hunter.io/api-keys
HUNTER_API_KEY=
